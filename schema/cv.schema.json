{
  "type": "object",
  "properties": {
    "personal": {
      "type": "object",
      "properties": {
        "name": {
          "type": "object",
          "properties": {
            "en": {
              "type": "string"
            },
            "hu": {
              "type": "string"
            }
          },
          "required": [
            "en",
            "hu"
          ],
          "additionalProperties": false
        },
        "title": {
          "$ref": "#/properties/personal/properties/name"
        },
        "picture": {
          "type": "string"
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "platform": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "icon": {
                "type": "object",
                "properties": {
                  "dark": {
                    "type": "string"
                  },
                  "light": {
                    "type": "string"
                  }
                },
                "required": [
                  "dark",
                  "light"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "platform",
              "url",
              "icon"
            ],
            "additionalProperties": false
          }
        },
        "contact": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "location",
                  "phone",
                  "email",
                  "link"
                ]
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "value"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "name",
        "title",
        "picture",
        "links",
        "contact"
      ],
      "additionalProperties": false
    },
    "workExperience": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "$ref": "#/properties/personal/properties/name"
          },
          "company": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "link": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "additionalProperties": false
          },
          "employmentType": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "from": {
            "type": "object",
            "properties": {
              "year": {
                "type": "integer"
              },
              "month": {
                "type": "integer",
                "minimum": 1,
                "maximum": 12
              }
            },
            "additionalProperties": false
          },
          "end": {
            "$ref": "#/properties/workExperience/items/properties/from"
          },
          "description": {
            "$ref": "#/properties/personal/properties/name"
          },
          "technologies": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "link": {
                  "type": "string"
                }
              },
              "required": [
                "name",
                "link"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "title",
          "company",
          "location",
          "from",
          "description",
          "technologies"
        ],
        "additionalProperties": false
      }
    },
    "educations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "degree": {
            "$ref": "#/properties/personal/properties/name"
