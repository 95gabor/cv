            "additionalProperties": false
          },
          "location": {
            "type": "string"
          },
          "from": {
            "$ref": "#/properties/workExperience/items/properties/from"
          },
          "end": {
            "$ref": "#/properties/workExperience/items/properties/from"
          },
          "note": {
            "$ref": "#/properties/personal/properties/name"
          }
        },
        "required": [
          "degree",
          "institution",
          "location",
          "from"
        ],
        "additionalProperties": false
