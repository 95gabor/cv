# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — copy from `source scripts/export-supabase-env.sh` after `supabase start`
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=<from supabase status: PUBLISHABLE_KEY>
# Seed only (writes) — never use for static build / publish
SUPABASE_SECRET_KEY=<from supabase status: SECRET_KEY>

# Legacy JWT keys (optional fallback until removed by Supabase ~late 2026)
# SUPABASE_ANON_KEY=<from supabase status: ANON_KEY>
# SUPABASE_SERVICE_ROLE_KEY=<from supabase status: SERVICE_ROLE_KEY>

# Analytics (production only)
NEXT_PUBLIC_GA_ID=G-QV2E7L8324
